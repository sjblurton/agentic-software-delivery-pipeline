# Supabase project URL (for local Docker use the local API URL)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase publishable key (safe for browser usage)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Postgres connection string for Drizzle (local Docker default: postgresql://postgres:postgres@127.0.0.1:54322/postgres)
DATABASE_URL=
